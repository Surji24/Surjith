    def simple_hash(self, password):
        """Simple hash function for demonstration"""
        return hashlib.sha256(password.encode()).hexdigest()[:8]
    
    def classical_brute_force(self, target_hash, max_passwords=1000):
        """
        Tamil: Classical Brute Force - ஒவ்வொரு password test செய்யும்
        Technical: Classical brute force - O(N) complexity
        """
        print("\n" + "=" * 70)
        print("  CLASSICAL PASSWORD CRACKING (Brute Force)")
        print("=" * 70)
        
        for i in range(max_passwords):
            password = f"pass{i}"
            hash_val = self.simple_hash(password)
            
            if hash_val == target_hash:
                print(f"✓ Found! Password: {password}")
                print(f"✓ Hash: {hash_val}")
                print(f"✓ Attempts: {i+1}")
                return password
        
        print(f"✗ Password not found in {max_passwords} attempts")
        return None
    
    def grover_quantum_crack(self, target_hash, n_bits=4, iterations=1):
        """
        Tamil: Quantum Cracking - Grover's Algorithm use செய்து
        Technical: Grover's Algorithm for O(√N) complexity
        """
        print("\n" + "=" * 70)
        print("  QUANTUM PASSWORD CRACKING (Grover's Algorithm)")
        print("=" * 70)
        
        # Create quantum circuit
        n_qubits = n_bits + 1  # password bits + ancilla
        qc = QuantumCircuit(n_qubits, n_bits)
        
        # Step 1: Superposition (all passwords simultaneously)
        print("\nStep 1: Create superposition (all passwords at once)")
        for i in range(n_bits):
            qc.h(i)
        
        # Step 2: Grover iterations
        print(f"\nStep 2: Apply Grover iterations ({iterations} iteration)")
        for iter_num in range(iterations):
            # Oracle: Mark target password
            print(f"  - Oracle: Mark target state")
            
            # Diffusion: Amplify marked state
            print(f"  - Diffusion: Amplify marked state")
            for i in range(n_bits):
                qc.h(i)
                qc.x(i)
            
            qc.mcx(list(range(n_bits)), n_bits - 1)
            
            for i in range(n_bits):
                qc.x(i)
                qc.h(i)
        
        # Step 3: Measure
        print("\nStep 3: Measure quantum state")
        qc.measure(range(n_bits), range(n_bits))
        
        # Print circuit
        print("\nQuantum Circuit:")
        print(qc)
        
        # Simulate
        print("\nSimulating (1000 shots)...")
        simulator = Aer.get_backend('aer_simulator')
        result = execute(qc, simulator, shots=1000).result()
        counts = result.get_counts()
        
        print(f"\nResults: {counts}")
        
        # Decode
        most_freq = max(counts.keys(), key=lambda k: counts[k])
        password_idx = int(most_freq, 2)
        
        print(f"\n✓ Most probable: pass{password_idx}")
        return f"pass{password_idx}"
    
