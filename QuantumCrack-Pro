from qiskit import QuantumCircuit, Aer, execute
import hashlib
import numpy as np

class QuantumPasswordCracker:
    """
    Tamil: குவாண்டம் Password Cracker - Grover's Algorithm பயன்படுத்தி
    Technical: Quantum Password Cracker using Grover's Algorithm
